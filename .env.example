# ╔══════════════════════════════════════════════════════════════════╗
# ║  Zokai™ Station — Environment Configuration Template           ║
# ║                                                                ║
# ║  Copy this file to .env.free / .env.pro / .env.mkn             ║
# ║  Or use: ./installer.sh --tier free  (auto-generates for you)  ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# The installer (installer.sh) auto-generates a per-tier .env file
# with correct defaults. This template documents ALL variables for
# manual setup or reference.
#
# API keys and secrets are stored separately in ../secrets/*.txt
# (NOT in this file). See secrets/secrets.template for details.


# ─── Identity & Tier ─────────────────────────────────────────────
# REQUIRED — determines instance name, ports, subnets, and services.

TIER="free"
# Options: free | pro | mkn
# - free: Core + base MCPs (no Postgres, no Gap Indexer)
# - pro:  Core + base MCPs + Postgres + Gap Indexer
# - mkn:  Pro + Raindrop MCP (internal development tier)

LLM_MODE="cloud"
# Options: cloud | local | hybrid
# - cloud:  OpenRouter / GLM (requires API key)
# - local:  Ollama on host (no internet needed)
# - hybrid: Cloud primary, local fallback

ZOKAI_INSTANCE="zokai-free"
# Docker project name prefix. All containers named ${ZOKAI_INSTANCE}-<service>.
# Auto-derived from TIER: free → zokai-free, pro → zokai-pro, mkn → zokai-mkn

COMPOSE_PROJECT_NAME="zokai-free"
# Must match ZOKAI_INSTANCE for Docker Compose.

PROFILE="ff"
# Legacy compat. free → ff, pro → pro, mkn → hybrid


# ─── VS Code & Authentication ───────────────────────────────────

VSCODE_PORT="8081"
# Host port for the VS Code web UI.
# free: 8081 | pro: 8082 | mkn: 8080

VSCODE_PASSWORD="changeme"
# Auto-generated by installer (openssl rand -hex 16).
# REQUIRED — protects the web-based VS Code instance.


# ─── LLM & Embedding Configuration ──────────────────────────────

LLM_PROVIDER="openrouter"
# Options: openrouter | ollama

# EMBEDDING_PROVIDER is DEPRECATED — do NOT set.
# GPTR embeddings configured via EMBEDDING + EMBEDDING_KWARGS in docker-compose.yml.

EMBEDDING_MODEL_ID="sentence-transformers/paraphrase-multilingual-mpnet-base-v2"
# Model baked into the embedding-server Docker image.

EMBEDDING_DIMENSIONS="768"
# Must match the model output dimensions. Do NOT change without
# recreating all Qdrant collections (Lesson #5).

ENABLE_EXTERNAL_TOOLS="true"
# false in local-only LLM mode (disables web research tools).

# GPTR-MCP LLM settings (defaults for free tier):
FAST_LLM="openrouter:z-ai/glm-4.5-air:free"
SMART_LLM="openrouter:meta-llama/llama-3.3-70b-instruct:free"
# GPTR embedding: configured in docker-compose.yml (local FastEmbed server)
# No env var needed — defaults to openai:embed → http://embedding-server:7997/v1
RETRIEVER="duckduckgo"
# Options: duckduckgo (keyless) | tavily (requires API key in secrets/)


# ─── Network Subnets (Per-Tier Isolation) ────────────────────────
# Each tier gets dedicated subnets to allow parallel deployment.
# Defaults shown are for the FREE tier.

SUBNET_FRONTEND="172.31.0.0/16"
GW_FRONTEND="172.31.0.1"
SUBNET_BACKEND="172.32.0.0/16"
GW_BACKEND="172.32.0.1"
SUBNET_DATA="172.33.0.0/16"
GW_DATA="172.33.0.1"
SUBNET_MGMT="172.34.0.0/16"
GW_MGMT="172.34.0.1"

# Pro subnets: 172.41-44.x | MKN subnets: 172.21-24.x
# Dev mode shifts by +20 (e.g. free-dev: 172.51.x)


# ─── Service Ports ───────────────────────────────────────────────
# Offset by tier: mkn = base, free = base+100, pro = base+200.
# Defaults shown are for the FREE tier.

NGINX_HTTP_PORT="180"
NGINX_HTTPS_PORT="543"
GMAIL_MCP_PORT="8107"
GMAIL_DASHBOARD_PORT="8117"
CALENDAR_MCP_PORT="8108"
CALENDAR_DASHBOARD_PORT="8118"
QDRANT_PORT="16433"
QDRANT_GRPC_PORT="16434"
REDIS_PORT="6479"
POSTGRES_PORT="54422"
WORKSPACE_MGR_PORT="9100"
SECRETS_MGR_PORT="9101"
OAUTH_CALLBACK_PORT="9102"


# ─── Data Paths ──────────────────────────────────────────────────
# All persistent data lives outside the repo in DATA_DIR.
# The installer auto-creates these directories.

DATA_DIR="$HOME/Documents/ZokaiData-free"
# Base directory for all persistent data.
# free: ZokaiData-free | pro: ZokaiData-pro | mkn: ZokaiData

WORKSPACE_DIR=$DATA_DIR/workspaces
# User-facing workspace (notes, outputs). Per-tier, inside DATA_DIR.

QDRANT_DATA_DIR="$DATA_DIR/qdrant/storage"
REDIS_DATA_DIR="$DATA_DIR/redis/data"
POSTGRES_DATA_DIR="$DATA_DIR/postgres/data"
VSCODE_SETTINGS_DIR="$DATA_DIR/vscode-settings"
ATTACHMENTS_DIR="$DATA_DIR/attachments"
LOGS_DIR="$DATA_DIR/logs"
SECRETS_DIR="$DATA_DIR/secrets"
# All default to subdirectories of DATA_DIR.

MCP_SERVERS_DIR="./mcp-servers/memory-kg-mcp"
# Path to the host-native memory-kg-mcp Node.js server.

MAX_ATTACHMENT_SIZE_MB="25"
# Maximum email attachment size to download (in MB).


# ─── Security ────────────────────────────────────────────────────

REDIS_PASSWORD="changeme"
# REQUIRED — auto-generated by installer (openssl rand -hex 32).
# Used by Redis, calendar-mcp, and ingestor.

HOST_UID="1000"
HOST_GID="1000"
# UID/GID for non-root container users. Set to your host user's
# UID/GID to avoid permission issues with bind-mounted volumes.
# On macOS: id -u / id -g

TZ="Europe/Berlin"
# Timezone for container services. Used by calendar-mcp and ingestor.


# ═════════════════════════════════════════════════════════════════
# API keys and credentials are NOT stored in .env.
# They live in ../secrets/ (or $SECRETS_DIR) as individual files:
#
#   openai-api-key.txt       — OpenRouter/OpenAI API key
#   openrouter-api-key.txt   — OpenRouter API key (copy of above)
#   anthropic-api-key.txt    — Anthropic/Claude API key
#   tavily-api-key.txt       — Tavily web search key (optional)
#   github-token.txt         — GitHub PAT (optional)
#   youtube-api-key.txt      — YouTube Data API key (optional)
#   raindrop-token.txt       — Raindrop.io API token (mkn only)
#   google-api-key.txt       — Google Search API key (optional)
#   google-cx.txt            — Google Custom Search Engine ID (optional)
#   supabase-key.txt         — Supabase key (optional)
#   postgres-password.txt    — Postgres password (pro/mkn only)
#   zai-api-key.txt          — Z.ai API key (optional)
#   token.json               — Google OAuth token (auto-generated)
#   credentials.json         — Google OAuth client credentials
#
# See: secrets/secrets.template for a copyable template.
# ═════════════════════════════════════════════════════════════════
