<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bundle identity -->
    <key>CFBundleIdentifier</key>
    <string>com.zokai.station</string>

    <key>CFBundleName</key>
    <string>Zokai Station</string>

    <key>CFBundleDisplayName</key>
    <string>Zokai Station</string>

    <!-- Executable -->
    <key>CFBundleExecutable</key>
    <string>zokai-launcher</string>

    <!-- Icon -->
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>

    <!-- Version -->
    <key>CFBundleVersion</key>
    <string>1.0.0</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0</string>

    <!-- Bundle type -->
    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleSignature</key>
    <string>????</string>

    <!-- OS requirements -->
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>

    <!-- LSUIElement = true: no Dock icon bounce, no app menu.
         Chrome (the actual UI) becomes the visible app. -->
    <key>LSUIElement</key>
    <true/>

    <!-- Architecture -->
    <key>LSArchitecturePriority</key>
    <array>
        <string>arm64</string>
        <string>x86_64</string>
    </array>

    <!-- Privacy descriptions (required by Gatekeeper for apps requesting access) -->
    <key>NSAppleEventsUsageDescription</key>
    <string>Zokai Station uses Apple Events to display launch progress dialogs.</string>
</dict>
</plist>
